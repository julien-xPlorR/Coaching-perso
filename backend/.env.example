# ── Configuration Strava ───────────────────────────────────────────────
# Crée une application sur https://www.strava.com/settings/api
# puis reporte ici tes identifiants (le secret reste sur TA machine).
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Doit correspondre au domaine "Authorization Callback Domain" = localhost
STRAVA_REDIRECT_URI=http://localhost:8787/api/strava/callback

# Port du backend
PORT=8787
