# ── SOMMET backend — variables d'environnement ────────────────────────────
# En LOCAL : ne définis PAS DATABASE_URL -> le backend utilise node:sqlite
#            (fichier backend/sommet.db). Rien à installer.
#
# EN LIGNE (Render + Neon) : définis DATABASE_URL -> bascule sur PostgreSQL.

# Base PostgreSQL Neon (chaîne de connexion POOLED, celle dont l'hôte contient
# "-pooler"). Laisser vide en local.
# Exemple :
# DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Vérification stricte du certificat TLS Postgres (défaut: false).
# Mettre true si l'environnement dispose des autorités de certification.
# PGSSL_STRICT=false

# Taille max du pool de connexions Postgres (défaut: 5).
# PG_POOL_MAX=5

# ── Strava OAuth ──────────────────────────────────────────────────────────
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# En ligne, mets l'URL publique Render, ex. :
# STRAVA_REDIRECT_URI=https://sommet.onrender.com/api/strava/callback
STRAVA_REDIRECT_URI=

# Port (Render l'injecte automatiquement ; en local, défaut 8787)
# PORT=8787
